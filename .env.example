SECRET_KEY=
SQLALCHEMY_DATABASE_URI=
SQLALCHEMY_TRACK_MODIFICATIONS=
OPENAI_API_KEY=
OPENAI_MODEL="gpt-4o-mini"
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# Google Sign-In (OAuth 2.0 Web client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# In Google Cloud Console: APIs & Services > Credentials > your OAuth 2.0 Client ID
# Authorized JavaScript origins (examples for local dev):
#   http://127.0.0.1:5000
#   http://localhost:5000
# Authorized redirect URIs must match the URL Flask builds for auth.authorize (no /auth prefix):
#   http://127.0.0.1:5000/authorize
#   http://localhost:5000/authorize
# Use the same host (127.0.0.1 vs localhost) and port you use in the browser, or you will get redirect_uri_mismatch.
